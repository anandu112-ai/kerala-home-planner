# Kerala Home Planner — Frontend Environment Variables
# Copy this file to .env and fill in the values for local development.
# On Vercel, set these under Project Settings → Environment Variables.

# ── Server-side proxy (SSR) ──────────────────────────────────────────────────
# URL of the deployed FastAPI backend (Render).
# Read at request time by the Node.js SSR server in src/services/serverPredict.ts.
# In local dev this defaults to http://127.0.0.1:8000 if unset.
BACKEND_URL=http://127.0.0.1:8000

# ── Client-side direct calls (optional) ─────────────────────────────────────
# VITE_* variables are baked in at build time.
# Only needed if you want the browser to call the backend directly (not via SSR proxy).
# On Vercel, set this to your Render backend URL.
# VITE_API_URL=https://kerala-home-planner-backend.onrender.com
