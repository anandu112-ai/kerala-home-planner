PROJECT_NAME=Kerala Home Planner API

API_VERSION=v1

MODEL_PATH=models/House_Model.pkl

# Set to your Vercel frontend URL so CORS allows your deployment.
# Example: https://kerala-home-planner.vercel.app
# Also allows *.lovable.app and *.vercel.app automatically via regex.
FRONTEND_URL=http://localhost:5173

ENVIRONMENT=development

# ---------------------------------------------------
# LLM API Keys for Site Condition Analysis (optional)
# ---------------------------------------------------
# Set ONE of the following in your Render service environment variables.
# The backend auto-detects the provider from the key present.
#
# Option A — Google Gemini (recommended, free tier available)
GEMINI_API_KEY=your_gemini_api_key_here
#
# Option B — OpenAI
# OPENAI_API_KEY=your_openai_api_key_here
#
# Optional: Explicitly set provider ("gemini" or "openai")
# LLM_PROVIDER=gemini
#
# If neither key is set, site_description is ignored and only
# the base ML prediction is returned (graceful fallback — no crash).
