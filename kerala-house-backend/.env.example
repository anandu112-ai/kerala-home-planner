# ── Kerala House Price Prediction API — environment variables ──────────────
# Copy this file to .env and fill in your values for local development.
# On Cloud Run, set these via:  gcloud run deploy ... --set-env-vars KEY=VALUE


# ── LLM API key (set ONE of the following) ────────────────────────────────
# Google Gemini (recommended — free tier available at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (alternative)
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: force a specific provider ("gemini" or "openai")
# LLM_PROVIDER=gemini

# Optional: generic key override (auto-detected by prefix: sk-* → openai, else → gemini)
# LLM_API_KEY=your_key_here


# ── CORS ──────────────────────────────────────────────────────────────────
# Set to your deployed frontend URL so the browser doesn't block requests.
FRONTEND_URL=http://localhost:5173


# ── Model path (default: models/house_model.pkl) ──────────────────────────
# Change only if you rename or move the model file.
# MODEL_PATH=models/house_model.pkl
